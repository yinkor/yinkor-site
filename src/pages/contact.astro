---
import Layout from '~/layouts/PageLayout.astro';
---
<Layout metadata={{ title: 'Contact Yinkor' }}>
  <div class="container mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold">Contact Us</h1>
    <div class="grid md:grid-cols-2 gap-10 mt-8">
      <div>
        <p><strong>Email:</strong> info@yindk.com</p>
        <p><strong>WhatsApp/Phone:</strong> +86 13567882409</p>
        <p><strong>Address:</strong> No.26 Beilun District, Ningbo, China</p>
      </div>
      <div>
        <form action="https://formspree.io/f/your-endpoint" method="POST" class="space-y-4">
          <input type="text" name="name" placeholder="Your Name" class="w-full border p-2 rounded" required>
          <input type="email" name="email" placeholder="Your Email" class="w-full border p-2 rounded" required>
          <textarea name="message" placeholder="Your Message" rows="5" class="w-full border p-2 rounded" required></textarea>
          <button type="submit" class="bg-blue-700 text-white px-4 py-2 rounded">Send Inquiry</button>
        </form>
      </div>
    </div>
  </div>
</Layout>