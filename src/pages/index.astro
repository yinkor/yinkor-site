---
import Layout from '~/layouts/PageLayout.astro';
const metadata = { title: 'Yinkor' };
---
<Layout metadata={metadata}>
  <div class="container mx-auto px-4 py-20 text-center">
    <h1 class="text-4xl font-bold">Yinkor Industrial Automation</h1>
    <p class="mt-4 text-xl">Flow | Pressure | Temperature | Level | Analytical | Control</p>
    <a href="/contact" class="mt-8 inline-block bg-blue-600 text-white px-6 py-3 rounded">Contact Us</a>
  </div>
</Layout>