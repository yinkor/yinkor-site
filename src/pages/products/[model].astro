---
import Layout from '~/layouts/PageLayout.astro';
import allProducts from '../../data/products.json';

export function getStaticPaths() {
  return allProducts.map((product) => ({
    params: { model: product.model },
    props: { product },
  }));
}

const { product } = Astro.props;
if (!product) return <Layout>Product not found</Layout>;

const pageTitle = `${product.model} - ${product.brand} - Yinkor`;
const pageDesc = product.description ? product.description.slice(0, 160) : '';
const metadata = { title: pageTitle, description: pageDesc };
---

<Layout metadata={metadata}>
  <div class="container mx-auto px-4 py-10">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-3xl font-bold">{product.model} – {product.brand}</h1>
      <p class="text-gray-600 mt-2">{product.category} / {product.subcategory} / {product.series}</p>
      <div class="grid md:grid-cols-2 gap-8 mt-8">
        <div>
          {product.image && <img src={product.image} alt={product.model} class="w-full rounded shadow" />}
        </div>
        <div>
          <p class="text-lg">{product.description}</p>
          <div class="mt-6 space-x-3">
            {product.datasheet && <a href={product.datasheet} class="bg-blue-700 text-white px-4 py-2 rounded inline-block">📄 Download Datasheet</a>}
            <a href="/contact" class="bg-green-700 text-white px-4 py-2 rounded inline-block">💰 Get a Quote</a>
          </div>
        </div>
      </div>
      {product.faq_q1 && (
        <div class="mt-12">
          <h2 class="text-2xl font-bold">Frequently Asked Questions</h2>
          <div class="mt-4 space-y-4">
            <div>
              <h3 class="font-semibold">Q: {product.faq_q1}</h3>
              <p>A: {product.faq_a1}</p>
            </div>
            {product.faq_q2 && (
              <div>
                <h3 class="font-semibold">Q: {product.faq_q2}</h3>
                <p>A: {product.faq_a2}</p>
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  </div>
</Layout>