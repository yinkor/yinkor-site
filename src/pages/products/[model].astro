---
import Layout from '~/layouts/PageLayout.astro';

export function getStaticPaths() {
  const products = [
    {
      model: 'CMF300M',
      brand: 'Emerson',
    }
  ];
  return products.map((product) => ({
    params: { model: product.model },
    props: { product },
  }));
}

const { product } = Astro.props;
---

<Layout>
  <h1>{product.model} – {product.brand}</h1>
</Layout>
