---
import Layout from '~/layouts/PageLayout.astro';

export function getStaticPaths() {
  const products = [
    {
      model: 'CMF300M',
      brand: 'Emerson',
      category: 'Flow Measurement',
      subcategory: 'Coriolis',
      series: 'Micro Motion ELITE',
      description: 'High accuracy Coriolis flow meter.',
    }
  ];
  return products.map((p) => ({ params: { model: p.model }, props: { product: p } }));
}

const { product } = Astro.props;
---

<Layout>
  <h1>{product.model}</h1>
  <p>{product.description}</p>
</Layout>
